{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/favicon.ico"]
  },
  "routes": [
    {
      "route": "/login",
      "serve": "/index.html"
    },
    {
      "route": "/forgot-password",
      "serve": "/index.html"
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY"
  },
  "mimeTypes": {
    ".html": "text/html",
    ".js": "application/javascript"
  }
}
